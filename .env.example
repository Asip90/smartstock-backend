# Copier en .env (local) ou définir comme variables d'environnement sur Railway.

# Django
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=*

# Base de données (Railway fournit DATABASE_URL automatiquement avec Postgres ;
# en local sans Postgres, laisser vide -> SQLite).
DATABASE_URL=

# FedaPay (https://fedapay.com) — clé SECRÈTE (jamais côté app !)
FEDAPAY_SECRET_KEY=sk_sandbox_xxx
FEDAPAY_ENV=sandbox            # sandbox | live
FEDAPAY_WEBHOOK_SECRET=wh_xxx  # secret de signature du webhook

# Firebase admin : contenu JSON du compte de service (une seule ligne),
# OU chemin vers le fichier. Sur Railway, coller le JSON dans cette variable.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Tarifs (en FCFA)
PRICE_MONTHLY=1900
PRICE_YEARLY=15000
